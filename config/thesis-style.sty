\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{config/thesis-style}[2026/07/18 Bilingual thesis template]
\PassOptionsToPackage{table}{xcolor}
\RequirePackage{iftex}
\ifPDFTeX
  \RequirePackage[T1]{fontenc}\RequirePackage[utf8]{inputenc}
  \RequirePackage{newtxtext,newtxmath}
\else
  \RequirePackage{fontspec}
  \defaultfontfeatures{Ligatures=TeX}
  \IfFontExistsTF{Times New Roman}{\setmainfont{Times New Roman}}{\setmainfont{TeX Gyre Termes}}
  \IfFontExistsTF{Consolas}{\setmonofont{Consolas}}{\setmonofont{Latin Modern Mono}}
  \RequirePackage{unicode-math}
\fi
\RequirePackage[main=\thesislanguage,polish,english]{babel}
% W polskiej wersji materialy uzupelniajace nazywamy zalacznikami.
% Babel uzywa formy pojedynczej przed litera konkretnego zalacznika.
\addto\captionspolish{\renewcommand{\appendixname}{Załącznik}}
\addto\captionsenglish{\renewcommand{\appendixname}{Appendix}}
\newcommand{\thesisappendicesname}{\ploren{Załączniki}{Appendices}}
\RequirePackage{csquotes,microtype,geometry,setspace,needspace,graphicx}
\RequirePackage[export]{adjustbox}
\RequirePackage{pdflscape,placeins}
% unicode-math dostarcza symbole AMS dla LuaLaTeX/XeLaTeX. Ponowne
% załadowanie amssymb powoduje m.in. konflikt definicji polecenia \eth.
\ifPDFTeX
  \RequirePackage{amsmath,amssymb}
\else
  \RequirePackage{amsmath}
\fi
\RequirePackage{booktabs,array,tabularx,longtable,siunitx}
\RequirePackage{enumitem,titlesec,tocloft,caption,subcaption,listings,xcolor}
\RequirePackage{menukeys}
\RequirePackage{tikz,pgfplots,circuitikz,fancyhdr,etoolbox}
\usetikzlibrary{arrows.meta,positioning,calc,shapes.geometric,shapes.multipart,fit}
% Dyskretne, czytelne odnosniki w PDF: spis tresci, rysunki, tabele,
% rownania, cytowania bibliograficzne i adresy internetowe.
\definecolor{thesislinkblue}{RGB}{0,70,125}
% Jasne tlo wyróżnionego wiersza pozostaje czytelne w druku monochromatycznym.
\definecolor{thesisrowhighlight}{RGB}{226,236,244}
% Semantyczne polecenia do zapisu skrótów klawiszowych i ścieżek menu.
% Ich wygląd można później zmienić centralnie, bez edycji treści rozdziałów.
\newcommand{\shortcut}[1]{\keys{#1}}
\newcommand{\menupath}[1]{\menu{#1}}
\RequirePackage[
  colorlinks=true,
  linkcolor=thesislinkblue,
  citecolor=thesislinkblue,
  urlcolor=thesislinkblue,
  filecolor=thesislinkblue,
  pdfusetitle
]{hyperref}
\RequirePackage{bookmark}
\RequirePackage[nameinlink,noabbrev]{cleveref}
\RequirePackage[
  backend=biber,
  style=ieee,
  citestyle=numeric-comp,
  sorting=none,
  sortcites=true,
  giveninits=true
]{biblatex}
\addbibresource{bibliografia.bib}
% W wykazie bibliografii wyróżniamy wyłącznie autorów. Ustawienie jest lokalne
% dla bibliografii, dlatego nie pogrubia nazwisk w cytowaniach w tekście.
\AtBeginBibliography{%
  \DeclareNameWrapperFormat{author}{\mkbibbold{#1}}%
}
\pgfplotsset{compat=1.18}
\usepgfplotslibrary{statistics}

% W PDF marginesy boczne sa rowne. W druku margines wewnetrzny jest
% nieco szerszy i automatycznie zamienia strony na kartkach parzystych.
\newcommand{\thesis@printmode@digital}{digital}
\newcommand{\thesis@printmode@print}{print}
\ifx\thesisprintmode\thesis@printmode@print
  \geometry{a4paper,top=2.5cm,bottom=2.5cm,inner=3cm,outer=2cm,headheight=15pt,headsep=0.7cm,footskip=1cm}
\else\ifx\thesisprintmode\thesis@printmode@digital
  \geometry{a4paper,top=2.5cm,bottom=2.5cm,left=2.5cm,right=2.5cm,headheight=15pt,headsep=0.7cm,footskip=1cm}
\else
  \PackageError{thesis-style}{Unknown thesis print mode}{Use digital or print in config/metadata.tex.}
\fi\fi
\onehalfspacing
% Akapity rozroznia wciecie pierwszego wiersza, bez dodatkowego odstepu.
% Pierwszy akapit po naglowku pozostaje bez wciecia zgodnie z klasycznym skladem.
\setlength{\parindent}{0.75cm}
\setlength{\parskip}{0pt}
\setcounter{secnumdepth}{3}\setcounter{tocdepth}{3}\emergencystretch=2em
\titleformat{\chapter}[hang]{\bfseries\fontsize{16}{19}\selectfont}{\thechapter.}{0.6em}{}
\titleformat{\section}[hang]{\bfseries\fontsize{14}{17}\selectfont}{\thesection}{0.6em}{}
\titleformat{\subsection}[hang]{\bfseries\fontsize{13}{16}\selectfont}{\thesubsection}{0.6em}{}
% Rozpoczęcie załączników zmienia numerację rozdziałów na literową oraz
% rozwija oznaczenie w nagłówku do „Załącznik A” / „Appendix A”.
\newcommand{\startthesisappendices}{%
  \appendix
  \titleformat{\chapter}[hang]
    {\bfseries\fontsize{16}{19}\selectfont}
    {\appendixname~\thechapter:}
    {0.6em}{}
}
\ifdefstring{\indentfirstparagraph}{true}{%
  \titlespacing{\chapter}{0pt}{0pt}{18pt}
  \titlespacing{\section}{0pt}{12pt}{6pt}
  \titlespacing{\subsection}{0pt}{12pt}{6pt}
}{%
  \titlespacing*{\chapter}{0pt}{0pt}{18pt}
  \titlespacing*{\section}{0pt}{12pt}{6pt}
  \titlespacing*{\subsection}{0pt}{12pt}{6pt}
}
% Zwarty, lecz czytelny spis treści. Bez dziedziczenia odstępu akapitowego.
\setlength{\cftbeforechapskip}{4pt}
\setlength{\cftbeforesecskip}{0pt}
\setlength{\cftbeforesubsecskip}{0pt}
\AtBeginDocument{\addtocontents{toc}{\protect\setlength{\parskip}{0pt}}}
\captionsetup{font=small,labelfont=bf,labelsep=period,justification=centering,skip=6pt}
\captionsetup[table]{position=top}
\numberwithin{equation}{chapter}
\setlist{topsep=6pt,itemsep=2pt,parsep=0pt}
% Listingi pozostaja czytelne w kolorowym PDF i po wydruku w skali szarosci.
\definecolor{thesiscodebackground}{RGB}{247,248,250}
\definecolor{thesiscodeframe}{RGB}{150,155,165}
\definecolor{thesiscodenumber}{RGB}{95,100,110}
\definecolor{thesiscodekeyword}{RGB}{0,65,120}
\definecolor{thesiscodecomment}{RGB}{40,105,65}
\definecolor{thesiscodestring}{RGB}{145,45,45}
% Pakiet listings nie dodaje automatycznie znakow Unicode o kodach > 255
% do listy znakow przetwarzanych jak litery. W LuaLaTeX-u i XeLaTeX-u brak
% tych deklaracji przesuwa m.in. ą, ę, ł, ś, ź i ż na poczatek fragmentu kodu.
% Bezposrednia rejestracja znakow zachowuje ich kolejnosc oraz kolorowanie.
\ifPDFTeX\else
  \begingroup
    \catcode0=12
    \makeatletter
    \g@addto@macro\lst@DefEC{%
      \lst@CCECUse\lst@ProcessLetter
      ąćęłńśźżĄĆĘŁŃŚŹŻ%
      ^^00%
    }%
  \endgroup
\fi
\lstdefinestyle{thesis}{
  basicstyle=\ttfamily\small,
  backgroundcolor=\color{thesiscodebackground},
  frame=single,
  rulecolor=\color{thesiscodeframe},
  framerule=0.4pt,
  columns=fullflexible,
  keepspaces=true,
  breaklines=true,
  breakatwhitespace=false,
  showstringspaces=false,
  numbers=left,
  numberstyle=\scriptsize\color{thesiscodenumber},
  numbersep=9pt,
  stepnumber=1,
  tabsize=4,
  captionpos=t,
  keywordstyle=\bfseries\color{thesiscodekeyword},
  commentstyle=\itshape\color{thesiscodecomment},
  stringstyle=\color{thesiscodestring},
  xleftmargin=1.25cm,
  framexleftmargin=1cm,
  aboveskip=12pt,
  belowskip=12pt
}
\lstdefinestyle{thesis-python}{style=thesis,language=Python}
\lstdefinestyle{thesis-matlab}{style=thesis,language=Matlab}
\lstdefinestyle{thesis-c}{style=thesis,language=C}
\lstdefinestyle{thesis-cpp}{style=thesis,language=[11]C++}
\lstdefinestyle{thesis-shell}{style=thesis,language=bash}
\lstdefinestyle{thesis-pseudocode}{
  style=thesis,
  morekeywords={ALGORYTM,WEJSCIE,WYJSCIE,DLA,OD,DO,JEZELI,WTEDY,
    WPRZECIWNYMRAZIE,KONIECJEZELI,KONIECDLA,ZWROC}
}
\lstset{style=thesis}
% Klasyczny pakiet listings przetwarza znaki UTF-8 bajtowo. Poniższe mapowanie
% jest bezpieczne dla pdfLaTeX-a; w LuaLaTeX-u kod źródłowy w listingach powinien
% pozostać ASCII albo zostać wczytany narzędziem obsługującym natywnie Unicode.
\ifPDFTeX
  \lstset{literate=
    {ą}{{\k{a}}}1 {ć}{{\'c}}1 {ę}{{\k{e}}}1 {ł}{{\l{}}}1
    {ń}{{\'n}}1 {ó}{{\'o}}1 {ś}{{\'s}}1 {ż}{{\.z}}1 {ź}{{\'z}}1
    {Ą}{{\k{A}}}1 {Ć}{{\'C}}1 {Ę}{{\k{E}}}1 {Ł}{{\L{}}}1
    {Ń}{{\'N}}1 {Ó}{{\'O}}1 {Ś}{{\'S}}1 {Ż}{{\.Z}}1 {Ź}{{\'Z}}1}
\fi
\AtBeginDocument{\counterwithin{lstlisting}{chapter}}
\renewcommand{\lstlistingname}{\ploren{Listing}{Listing}}
\renewcommand{\lstlistlistingname}{\ploren{Spis listingów}{List of listings}}
\captionsetup[lstlisting]{font=small,labelfont=bf,labelsep=period,justification=centering,skip=6pt}
\pagestyle{fancy}\fancyhf{}
\fancyhead[L]{\small\nouppercase{\leftmark}}\fancyhead[R]{\small\thepage}
\renewcommand{\headrulewidth}{0.4pt}
\fancypagestyle{plain}{\fancyhf{}\fancyfoot[C]{\thepage}\renewcommand{\headrulewidth}{0pt}}

% Duze elementy: grafika zachowuje proporcje i nie przekracza pola tekstowego.
% Opcjonalny argument moze nadpisac lub uzupelnic ustawienia includegraphics.
\newcommand{\thesisgraphic}[2][]{%
  \includegraphics[
    max width=\linewidth,
    max height=0.78\textheight,
    keepaspectratio,
    #1
  ]{#2}%
}

% Skalowanie szerokiego tabular/tabularx do aktualnej szerokosci tekstu.
% Nie stosuj do longtable, ktore samo dzieli sie pomiedzy stronami.
\newenvironment{thesiswidetable}
  {\begin{adjustbox}{max width=\linewidth}}
  {\end{adjustbox}}

% Pelna strona pozioma. clearpage utrzymuje elementy plywajace wewnatrz
% prawidlowej orientacji i zapobiega ich przeniesieniu poza to srodowisko.
\newenvironment{thesislandscape}
  {\clearpage\begin{landscape}}
  {\end{landscape}\clearpage}

\newcommand{\thesis@lang@polish}{polish}
\newcommand{\thesis@lang@english}{english}
\newcommand{\thesis@type@engineering}{engineering}
\newcommand{\thesis@type@master}{master}
\newcommand{\thesis@type@doctoral}{doctoral}
\newcommand{\thesis@status@draft}{draft}
\newcommand{\thesis@status@final}{final}
\newcommand{\ploren}[2]{\ifx\thesislanguage\thesis@lang@english #2\else #1\fi}
\newcommand{\thesistypename}{\ifx\thesistype\thesis@type@engineering\ploren{Praca dyplomowa inżynierska}{Engineering thesis}\else\ifx\thesistype\thesis@type@master\ploren{Praca dyplomowa magisterska}{Master's thesis}\else\ifx\thesistype\thesis@type@doctoral\ploren{Rozprawa doktorska}{Doctoral dissertation}\else\PackageError{thesis-style}{Unknown thesis type}{Use engineering, master or doctoral.}\fi\fi\fi}
\newcommand{\maintitle}{\ifx\thesislanguage\thesis@lang@english\titleen\else\titlepl\fi}
\newcommand{\mainuniversity}{\ifx\thesislanguage\thesis@lang@english\universityen\else\universitypl\fi}
\newcommand{\mainfaculty}{\ifx\thesislanguage\thesis@lang@english\facultyen\else\facultypl\fi}
\newcommand{\mainprogramme}{\ifx\thesislanguage\thesis@lang@english\programmeen\else\programmepl\fi}

% Walidacja podstawowych metadanych. W trybie draft generuje ostrzezenia,
% a w trybie final bledy kompilacji, ktorych nie nalezy ignorowac.
\newcommand{\thesis@validationissue}[1]{%
  \ifx\thesisstatus\thesis@status@final
    \PackageError{thesis-style}{#1}{Complete config/metadata.tex or change thesisstatus to draft.}%
  \else
    \PackageWarningNoLine{thesis-style}{#1}%
  \fi
}
\newcommand{\thesis@warnifdefault}[3]{%
  \ifdefstring{#1}{#2}{\thesis@validationissue{#3}}{}%
}
\newcommand{\thesis@validateboolean}[2]{%
  \ifdefstring{#1}{true}{}{%
    \ifdefstring{#1}{false}{}{\thesis@validationissue{Invalid value of #2: use true or false}}%
  }%
}
\newcommand{\thesis@validatedata}{%
  \ifx\thesisstatus\thesis@status@draft\else
    \ifx\thesisstatus\thesis@status@final\else
      \PackageError{thesis-style}{Invalid thesisstatus}{Use draft or final in config/metadata.tex.}%
    \fi
  \fi
  \thesis@warnifdefault{\authorname}{Imię i nazwisko}{Author name is still a placeholder}%
  \thesis@warnifdefault{\albumid}{000000}{Student ID is still a placeholder}%
  \thesis@warnifdefault{\titlepl}{Tytuł pracy w języku polskim}{Polish title is still a placeholder}%
  \thesis@warnifdefault{\titleen}{Thesis title in English}{English title is still a placeholder}%
  \thesis@warnifdefault{\programmepl}{Nazwa kierunku}{Polish programme name is still a placeholder}%
  \thesis@warnifdefault{\programmeen}{Study programme}{English programme name is still a placeholder}%
  \thesis@warnifdefault{\supervisorname}{dr hab. inż. Imię Nazwisko, prof. uczelni}{Supervisor name is still a placeholder}%
  \thesis@warnifdefault{\keywordspl}{słowo kluczowe 1, słowo kluczowe 2, słowo kluczowe 3}{Polish keywords are still placeholders}%
  \thesis@warnifdefault{\keywordsen}{keyword 1, keyword 2, keyword 3}{English keywords are still placeholders}%
  \IfFileExists{\universitylogo}{}{\thesis@validationissue{University logo file was not found}}%
  \thesis@validateboolean{\showlistoffigures}{showlistoffigures}%
  \thesis@validateboolean{\showlistoftables}{showlistoftables}%
  \thesis@validateboolean{\showlistoflistings}{showlistoflistings}%
  \thesis@validateboolean{\showabbreviationlist}{showabbreviationlist}%
  \thesis@validateboolean{\showsymbollist}{showsymbollist}%
  \thesis@validateboolean{\showdedication}{showdedication}%
  \thesis@validateboolean{\showaideclaration}{showaideclaration}%
  \thesis@validateboolean{\showacknowledgements}{showacknowledgements}%
  \thesis@validateboolean{\showfundingstatement}{showfundingstatement}%
  \thesis@validateboolean{\showavailabilitystatement}{showavailabilitystatement}%
  \thesis@validateboolean{\indentfirstparagraph}{indentfirstparagraph}%
}
\AtBeginDocument{\thesis@validatedata}

% Jednostki i liczby: kropka dziesietna w pracy angielskiej, przecinek w polskiej.
% Dane zrodlowe mozna zapisywac z kropka; siunitx dobierze format wyjsciowy.
\ifx\thesislanguage\thesis@lang@english
  \sisetup{
    locale=US,
    mode=match,
    per-mode=symbol,
    separate-uncertainty=true,
    range-phrase={--},
    range-units=single
  }
\else
  \sisetup{
    locale=PL,
    mode=match,
    per-mode=symbol,
    separate-uncertainty=true,
    range-phrase={--},
    range-units=single
  }
\fi

% Nazwy tworzone automatycznie przez \cref i \Cref.
\ifx\thesislanguage\thesis@lang@english
  \crefname{chapter}{chapter}{chapters}
  \Crefname{chapter}{Chapter}{Chapters}
  \crefname{section}{section}{sections}
  \Crefname{section}{Section}{Sections}
  \crefname{subsection}{section}{sections}
  \Crefname{subsection}{Section}{Sections}
  \crefname{figure}{figure}{figures}
  \Crefname{figure}{Figure}{Figures}
  \crefname{table}{table}{tables}
  \Crefname{table}{Table}{Tables}
  \crefname{equation}{equation}{equations}
  \Crefname{equation}{Equation}{Equations}
  \crefname{lstlisting}{listing}{listings}
  \Crefname{lstlisting}{Listing}{Listings}
\else
  \crefname{chapter}{rozdział}{rozdziały}
  \Crefname{chapter}{Rozdział}{Rozdziały}
  \crefname{section}{podrozdział}{podrozdziały}
  \Crefname{section}{Podrozdział}{Podrozdziały}
  \crefname{subsection}{podrozdział}{podrozdziały}
  \Crefname{subsection}{Podrozdział}{Podrozdziały}
  \crefname{figure}{rysunek}{rysunki}
  \Crefname{figure}{Rysunek}{Rysunki}
  \crefname{table}{tabela}{tabele}
  \Crefname{table}{Tabela}{Tabele}
  \crefname{equation}{równanie}{równania}
  \Crefname{equation}{Równanie}{Równania}
  \crefname{lstlisting}{listing}{listingi}
  \Crefname{lstlisting}{Listing}{Listingi}
  \AtBeginDocument{%
    \def\crefpairconjunction{ i~}%
    \def\crefmiddleconjunction{,~}%
    \def\creflastconjunction{ i~}%
  }
\fi
% Komendy językowe występują także w tytułach rozdziałów. Dla zakładek PDF
% przekazujemy hyperrefowi ich prostą, tekstową postać.
\ifx\thesislanguage\thesis@lang@english
  \pdfstringdefDisableCommands{\def\ploren#1#2{#2}}%
  \hypersetup{pdftitle={\titleen},pdfauthor={\authorname},pdfsubject={Thesis}}%
\else
  \pdfstringdefDisableCommands{\def\ploren#1#2{#1}}%
  \hypersetup{pdftitle={\titlepl},pdfauthor={\authorname},pdfsubject={Praca dyplomowa}}%
\fi

\newcommand{\makethesistitle}{\begin{titlepage}\thispagestyle{empty}\begin{center}
\IfFileExists{\universitylogo}{\includegraphics[width=\universitylogowidth]{\universitylogo}\par\vspace{0.7cm}}{}
{\bfseries\large\mainuniversity\par}\vspace{0.25cm}{\large\mainfaculty\par}\vspace{1.35cm}
{\bfseries\fontsize{15}{18}\selectfont\MakeUppercase{\thesistypename}\par}\vspace{1.25cm}
{\bfseries\fontsize{18}{22}\selectfont\maintitle\par}
\ifx\thesislanguage\thesis@lang@polish
  \vspace{0.55cm}{\itshape\fontsize{14}{17}\selectfont\titleen\par}%
\fi
\end{center}\vfill\begin{flushright}\begin{minipage}{0.52\textwidth}
\textbf{\authorname}\\\ploren{Numer albumu}{Student ID}: \albumid\\
\ploren{Kierunek}{Programme}: \mainprogramme\\[0.7cm]
\textbf{\ploren{Promotor}{Supervisor}:}\\\supervisorname
\ifdefempty{\auxsupervisorname}{}{\\[0.4cm]\textbf{\ploren{Promotor pomocniczy}{Auxiliary supervisor}:}\\\auxsupervisorname}
\end{minipage}\end{flushright}\vfill\begin{center}\city, \submissionyear\end{center}\end{titlepage}}

\newcommand{\printthesisbibliography}{\cleardoublepage\printbibliography[heading=bibintoc,title={\ploren{Bibliografia}{References}}]}

